  },
  "keyFeatures": [
    "User registration and JWT-based authentication",
    "Browse and join group trips",
    "Trip creation and management by Creators and Admins",
    "Real-time trip chat for enrolled participants",
    "Role-based access control (Viatger, Creador, Admin)",
    "Promotion request system for users to become trip creators",
    "Admin panel for user management and promotion approvals",
    "React + Vite frontend with React Router protected routes",
    "FastAPI backend with SQLAlchemy ORM"
  ],
  "publicApiSurface": [
    "POST /auth/login",
    "POST /auth/register",
    "GET /viatge/trips",
    "GET /viatge/trips/{id}",
    "POST /viatge/trips/{id}/enroll",
    "POST /viatge/trips/{id}/leave",
    "POST /viatge/promote-request",
    "GET /users/me",
    "PUT /users/me/{nom}/{bio}",
    "POST /creadorViatges/creator/trips",
    "PUT /creadorViatges/creator/trips/{id}",
    "GET /missatges/trips/{trip_id}/chat",
    "POST /missatges/trips/{trip_id}/chat/send",
    "GET /admin/users",
    "PUT /admin/users/{user_id}/promote",
    "GET /admin/users/promotions",
    "PUT /admin/promotions/{user_id}"
  ]
}
