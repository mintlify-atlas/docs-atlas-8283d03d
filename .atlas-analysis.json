{
  "projectType": "saas",
  "projectName": "TravelConnect",
  "projectDescription": "A full-stack travel planning platform where users can discover, join, and manage group trips, with role-based access for travelers, trip creators, and administrators.",
  "theme": "palm",
  "primaryColor": "#2563EB",
  "lightColor": "#EFF6FF",
  "darkColor": "#1E3A5F",
